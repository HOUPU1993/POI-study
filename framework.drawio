                <mxCell id="5" value="House Value / Income Ratio" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#0f3460;fontColor=#ffffff;fontSize=12;fontStyle=1;arcSize=10;" vertex="1" parent="1">
                    <mxGeometry x="577" y="165" width="460" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="6" value="Low Household Income&lt;br&gt;(same house value)&lt;br&gt;→ High Ratio&lt;br&gt;→ Stronger Asset-binding Effect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFBFB;strokeColor=#0f3460;fontSize=11;arcSize=10;" vertex="1" parent="1">
                    <mxGeometry x="410" y="225" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="7" value="High Household Income&lt;br&gt;(same house value)&lt;br&gt;→ Low Ratio&lt;br&gt;→ Weaker Asset-binding Effect" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FBFBFB;strokeColor=#0f3460;fontSize=11;arcSize=10;" vertex="1" parent="1">
                    <mxGeometry x="990" y="225" width="200" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="47" style="edgeStyle=none;html=1;dashed=1;" edge="1" parent="1" source="10" target="21">
