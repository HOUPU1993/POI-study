                <mxCell id="4" value="1: Relative Financial Exposure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#16213e;fontColor=#ffffff;fontSize=13;fontStyle=1;arcSize=10;" vertex="1" parent="1">
                    <mxGeometry x="410" y="100" width="780" height="45" as="geometry"/>
